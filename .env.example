APP_NAME=SEZY
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Porto-Novo
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sezy
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail (SendGrid / Mailgun en prod, log en local)
MAIL_MAILER=log
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@sezy.bj"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ----------------------------------------------------------------
# PAIEMENTS MOBILE MONEY & CARTE
# Mode "mock" = simulation locale sans appel réseau (par défaut).
# Passer à "live" + renseigner les clés une fois les comptes
# marchands obtenus auprès de chaque opérateur / agrégateur.
# ----------------------------------------------------------------
PAYMENT_MODE=mock

# PayDunya (agrégateur cartes + Mobile Money BJ)
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# MTN Mobile Money Bénin
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=sandbox

# Moov Money
MOOV_MONEY_API_KEY=
MOOV_MONEY_MERCHANT_ID=

# Wave
WAVE_API_KEY=
WAVE_MERCHANT_ID=

# SMS (notifications transactionnelles - Phase 2)
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

FILESYSTEM_DISK=public

VITE_APP_NAME="${APP_NAME}"
